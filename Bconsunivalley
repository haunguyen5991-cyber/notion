<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BDS Video Gallery</title>
  <style>
    /* Giữ nguyên cấu trúc khung của bạn từ file gốc */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { background: #f8f8f8; font-family: Arial, sans-serif; }
    
    .gallery {
      display: flex;
      flex-direction: column;
      height: 100vh;
      background: #f8f8f8;
    }
    
    .main-view {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #e8e8e8;
      position: relative;
      overflow: hidden;
    }
    
    .counter {
      position: absolute;
      top: 10px;
      left: 10px;
      background: rgba(0,0,0,0.6);
      color: white;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 12px;
      z-index: 10;
    }
    
    #mainMediaWrap {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    /* Tối ưu riêng để video chính không bị méo tỉ lệ */
    #mainMediaWrap video {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      background: #000;
    }
    
    .brand-label {
      position: absolute;
      bottom: 4px;
      right: 6px;
      font-size: 10px;
      color: rgba(0,0,0,0.12);
      font-weight: 500;
      pointer-events: none;
    }
    
    .thumb-rail {
      height: 110px;
      background: white;
      border-top: 1px solid #ddd;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow-x: auto;
      gap: 10px;
      padding: 5px;
    }
    
    .thumb {
      width: 88px;
      height: 88px;
      flex-shrink: 0;
      background: #000;
      border: 2px solid transparent;
      cursor: pointer;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    
    /* Hiển thị video thu nhỏ (thumbnail) */
    .thumb video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.6;
    }
    
    /* Biểu tượng nút Play nhỏ trên các ô thumbnail */
    .thumb::after {
      content: '▶';
      position: absolute;
      color: white;
      font-size: 14px;
      text-shadow: 0px 0px 4px rgba(0,0,0,0.8);
    }
    
    .thumb.active {
      border-color: #1f2937;
    }
    
    .thumb.active video {
      opacity: 1;
    }
    
    .thumb:hover {
      border-color: #999;
    }
  </style>
</head>
<body>
  <div class="gallery">
    <div class="main-view" id="mainView">
      <div class="counter" id="counter">1 / 2</div>
      <div id="mainMediaWrap"></div>
      <div class="brand-label">dulieunhapho.com</div>
    </div>
    <div class="thumb-rail" id="thumbRail"></div>
  </div>

  <script>
    // Đã nạp sẵn 2 link video Cloudinary của bạn
    const items = [
      { url: 'https://res.cloudinary.com/dcspxywol/video/upload/v1783455233/BCH_y0kwbe.mp4', type: 'video' },
      { url: 'https://res.cloudinary.com/dcspxywol/video/upload/v1783455243/BCH2_k2fq4m.mp4', type: 'video' }
    ];
    
    let currentIndex = 0;
    
    function updateMain() {
      const item = items[currentIndex];
      const wrap = document.getElementById('mainMediaWrap');
      wrap.innerHTML = '';
      
      // Trình phát chính hỗ trợ điều khiển (controls) và tự động phát tắt tiếng (autoplay muted) giúp vượt qua bộ lọc chặn trên Notion
      wrap.innerHTML = '<video src="' + item.url + '" autoplay muted playsinline controls></video>';
      
      document.getElementById('counter').textContent = (currentIndex + 1) + ' / ' + items.length;
      updateThumbs();
    }
    
    function updateThumbs() {
      document.querySelectorAll('.thumb').forEach((t, i) => {
        t.classList.toggle('active', i === currentIndex);
      });
    }
    
    function initThumbs() {
      const rail = document.getElementById('thumbRail');
      items.forEach((item, idx) => {
        const t = document.createElement('div');
        t.className = 'thumb' + (idx === 0 ? ' active' : '');
        
        // Sử dụng thuộc tính preload="metadata" để trình duyệt tự trích xuất giây đầu tiên của video làm ảnh đại diện (Thumbnail) cực nhanh
        t.innerHTML = '<video src="' + item.url + '" preload="metadata" muted></video>';
        t.onclick = () => { currentIndex = idx; updateMain(); };
        rail.appendChild(t);
      });
    }
    
    // Giữ nguyên tính năng chuyển video bằng nút mũi tên Trái/Phải từ mã gốc của bạn
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') currentIndex = (currentIndex - 1 + items.length) % items.length;
      if (e.key === 'ArrowRight') currentIndex = (currentIndex + 1) % items.length;
      updateMain();
    });
    
    initThumbs();
    updateMain();
  </script>
</body>
</html>
